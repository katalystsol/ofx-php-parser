{
    "name": "katalystsol/ofx-php-parser",
    "description": "OFX PHP parser library",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "ofx",
        "open financial exchange",
        "finance",
        "parser"
    ],
    "authors": [
        {
            "name": "Don Cranford",
            "email": "dev@katalystsolution.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-simplexml": "*",
        "ext-mbstring": "*",
        "ext-libxml": "*"
    },
    "autoload": {
        "psr-4": {
            "KatalystSolutions\\OFX\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    }
}
